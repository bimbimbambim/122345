# ─── Telegram ──────────────────────────────────────────────
BOT_TOKEN=your_bot_token_from_botfather
BOT_USERNAME=lensy_ai_bot
WEBAPP_URL=https://your-frontend.netlify.app

# ─── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/lensy_ai

# ─── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Replicate AI ──────────────────────────────────────────
REPLICATE_API_TOKEN=r8_your_replicate_token

# ─── AWS S3 (optional, for photo storage) ──────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=lensy-ai-photos
AWS_REGION=us-east-1

# ─── Security ──────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string-in-production
# Comma-separated Telegram user IDs allowed to access admin panel
ADMIN_TELEGRAM_IDS=123456789,987654321
# Long secret token for admin panel direct access
ADMIN_TOKEN=change-this-to-a-long-random-admin-token

# ─── App ───────────────────────────────────────────────────
DEBUG=false
API_URL=https://your-backend.railway.app
